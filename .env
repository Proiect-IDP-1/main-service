# --- Auth DB (postgres pentru auth-service) ---
AUTH_POSTGRES_USER=user
AUTH_POSTGRES_PASSWORD=password
AUTH_POSTGRES_DB=auth_db

# --- Tabletop DB (postgres pentru catalog + order) ---
STORE_POSTGRES_USER=admin
STORE_POSTGRES_PASSWORD=boardgamepassword
STORE_POSTGRES_DB=tabletop_db

# --- Connection string folosit de auth-service ---
DATABASE_URL=postgres://user:password@auth-db:5432/auth_db

# --- Connection params folosite de catalog + order pentru tabletop-db ---
ORDER_DB_HOST=tabletop-db
ORDER_DB_NAME=tabletop_db
ORDER_DB_USER=admin
ORDER_DB_PASS=boardgamepassword

# --- JWT ---
JWT_SECRET=super_secret_cheie_proiect_idp

# --- pgAdmin si Grafana credentials (folosesc aceeasi parola) ---
PGADMIN_EMAIL=admin@tabletop.ro
PGADMIN_PASSWORD=admin
